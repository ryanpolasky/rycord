# rycord configuration. copy this to .env.local and fill in your values.
# everything here is optional — defaults fall back to a demo set + a public
# Discogs username (eggyb0i) — but the experience is much better with real
# keys filled in.

# ====== deployment / SEO ======

# Public canonical origin used for metadata, OG/Twitter share URLs, JSON-LD,
# robots.txt, and sitemap.xml. Falls back to https://rycord.dev if unset.
# Set this per-environment (staging, preview, production) so crawlers don't
# index the wrong origin.
NEXT_PUBLIC_SITE_URL=https://rycord.dev

# ====== Discogs collection ======

# Username whose collection becomes the shelf. Folder 0 = all releases.
# Public collections work without a token; private/larger ones need a token.
DISCOGS_USER=eggyb0i

# Optional personal access token from https://www.discogs.com/settings/developers.
# Raises rate limit from 60/min unauthed to 60/min per-token, and required for
# private collections.
DISCOGS_TOKEN=

# ====== dev knobs ======

# Tile the loaded collection N times to preview a much larger shelf without
# needing an actual 250-record account. Each tile gets a fresh id suffix so
# React keys stay unique. 1 = no tiling.
MULTIPLY_RECORDS=1

# Persistent cache root. Defaults to ./data, which maps cleanly to:
#   volumes:
#     - ./data:/app/data
RYCORD_DATA_DIR=

# Set to 1 to print a one-shot histogram of Discogs format metadata while
# deciding whether to support variable 12"/10"/7" record sizing.
DISCOGS_DEBUG_FORMATS=0

# ====== info-panel "ai overview" ======

# Last.fm API key — secondary source for the per-record blurb in the info
# panel after Wikipedia misses.
# Get one at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# OpenRouter API key — AI fallback when Wikipedia/Last.fm have no summary. Generates
# a short essay per release_id, cached server-side so we generate once
# across all users.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

OPENROUTER_TIMEOUT_MS=10000

# OpenRouter model(s) to try, in order, for AI-generated blurbs. Comma-
# separated chain — the route iterates through them on any failure (429,
# 4xx, 5xx, short response) until one succeeds. Useful because free-tier
# models on Google AI Studio in particular get rate-limited aggressively.
#
# Leave blank to use the built-in chain (see DEFAULT_MODEL_CHAIN in
# app/api/description/[id]/route.ts — currently gpt-oss-120b →
# llama-3.3-70b → gemma-4-31b-it → glm-4.5-air, all :free).
#
# Single id pins to that one model only (no fallback). Examples:
#   OPENROUTER_MODEL=openai/gpt-oss-120b:free
#   OPENROUTER_MODEL=google/gemma-4-31b-it:free,openai/gpt-oss-120b:free
#
# Browse https://openrouter.ai/models?max_price=0 for current free options.
OPENROUTER_MODEL=
